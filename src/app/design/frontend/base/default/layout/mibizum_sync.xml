<?xml version="1.0"?>
<!--
  Mibizum_Sync (frontend layout).
  Injects the async SDK V1 script into the <head> of every page
  (the 'default' handle applies to the entire frontend).
-->
<layout version="0.1.0">
    <default>
        <reference name="head">
            <block type="mibizum_sync/frontend_config"
                   name="mibizum.sync.frontend.config"
                   as="mibizum_sync_config"
                   template="mibizum_sync/frontend/config.phtml" />
        </reference>
    </default>

    <!-- Smart Item (ingredient) public ficha: /{url_prefix}/{slug}.
         Handle = routeNodeKey(mibizum_sync_ingredient) + controller(index) + action(view). -->
    <mibizum_sync_ingredient_index_view>
        <reference name="root">
            <action method="setTemplate"><template>page/1column.phtml</template></action>
        </reference>
        <reference name="content">
            <block type="mibizum_sync/frontend_ingredient"
                   name="mibizum.sync.ingredient.view"
                   template="mibizum_sync/ingredient/view.phtml" />
        </reference>
    </mibizum_sync_ingredient_index_view>

    <!-- Smart Item listing page: /{url_prefix}/ (configurable title). -->
    <mibizum_sync_ingredient_index_index>
        <reference name="root">
            <action method="setTemplate"><template>page/1column.phtml</template></action>
        </reference>
        <reference name="content">
            <block type="mibizum_sync/frontend_ingredient"
                   name="mibizum.sync.ingredient.list"
                   template="mibizum_sync/ingredient/list.phtml" />
        </reference>
    </mibizum_sync_ingredient_index_index>
</layout>
