<?php
/**
 * @var Mibizum_Sync_Block_Frontend_Ingredient $this
 *
 * Public ficha of a Smart Item, rendered from the data structure returned by
 * GET /api/v1/smart-items/{slug} of the Mibizum SaaS (statusLabel, statusBg/Fg,
 * substatusLabel already enriched server-side).
 */
$si = $this->getSmartItem();
if (!$si) {
    return;
}
$substituteUrl = $this->getSubstituteUrl();
$history       = $this->getPublicHistory();
?>
<div class="mibizum-ingredient-view" style="max-width: 920px; margin: 0 auto; padding: 1.5rem;">

    <header style="margin-bottom: 1.5rem;">
        <h1 style="margin: 0 0 0.6rem; font-size: 2rem;"><?php echo $this->htmlEscape($si['name']); ?></h1>

        <?php if (!empty($si['statusLabel'])): ?>
            <span style="display: inline-block; padding: 0.3rem 0.9rem; border-radius: 999px; font-size: 0.9rem;
                         background: <?php echo $this->htmlEscape($si['statusBg'] ?: '#E0E0E0'); ?>;
                         color: <?php echo $this->htmlEscape($si['statusFg'] ?: '#222'); ?>;">
                <?php echo $this->htmlEscape($si['statusLabel']); ?>
            </span>
        <?php endif; ?>

        <?php if (!empty($si['substatusLabel'])): ?>
            <span class="muted" style="margin-left: 0.5rem; font-size: 0.9rem; color: #666;">
                · <?php echo $this->htmlEscape($si['substatusLabel']); ?>
            </span>
        <?php endif; ?>
    </header>

    <?php if (!empty($si['description'])): ?>
        <section style="margin-bottom: 2rem; line-height: 1.6; font-size: 1rem;">
            <?php echo nl2br($this->htmlEscape($si['description'])); ?>
        </section>
    <?php endif; ?>

    <?php if (!empty($si['hasSubstitute'])): ?>
        <section style="margin-bottom: 2rem; background: #F8F9FA; border-left: 4px solid #0D47A1; padding: 1rem 1.2rem; border-radius: 4px;">
            <h2 style="margin: 0 0 0.5rem; font-size: 1.1rem;"><?php echo $this->__('Recommended substitute'); ?></h2>
            <?php if (!empty($si['substituteExtendedDescription'])): ?>
                <p style="margin: 0 0 0.6rem;"><?php echo nl2br($this->htmlEscape($si['substituteExtendedDescription'])); ?></p>
            <?php endif; ?>
            <?php if ($substituteUrl): ?>
                <a href="<?php echo $this->htmlEscape($substituteUrl); ?>"
                   style="display: inline-block; margin-top: 0.4rem; padding: 0.5rem 1rem; background: #0D47A1; color: #fff; text-decoration: none; border-radius: 4px;">
                    <?php echo $this->__('View substitute product'); ?> &rarr;
                </a>
            <?php elseif (!empty($si['substituteProductId'])): ?>
                <small class="muted" style="color: #666;">
                    <?php echo $this->__('Substitute product'); ?>: <code><?php echo $this->htmlEscape($si['substituteProductId']); ?></code>
                </small>
            <?php endif; ?>
            <?php if (!empty($si['substituteFormulationGuide'])): ?>
                <details style="margin-top: 0.8rem;">
                    <summary style="cursor: pointer; font-weight: 500;"><?php echo $this->__('Formulation guide'); ?></summary>
                    <div style="margin-top: 0.5rem; padding-left: 1rem; line-height: 1.5;">
                        <?php echo nl2br($this->htmlEscape($si['substituteFormulationGuide'])); ?>
                    </div>
                </details>
            <?php endif; ?>
        </section>
    <?php endif; ?>

    <?php if (count($history) > 0): ?>
        <section style="margin-top: 2rem; border-top: 1px solid #EEE; padding-top: 1.5rem;">
            <h2 style="margin: 0 0 1rem; font-size: 1.1rem;"><?php echo $this->__('History'); ?></h2>
            <ul style="list-style: none; padding: 0; margin: 0;">
                <?php foreach ($history as $h): ?>
                    <li style="margin-bottom: 0.8rem; padding-left: 1rem; border-left: 2px solid #EEE;">
                        <small style="color: #888; display: block; margin-bottom: 0.2rem;">
                            <?php echo $this->htmlEscape(date('d/m/Y', strtotime($h['changedAt']))); ?>
                            <?php if (!empty($h['newStatus'])): ?> · <?php echo $this->htmlEscape($h['newStatus']); ?><?php endif; ?>
                            <?php if (!empty($h['changedByLabel'])): ?> · <?php echo $this->htmlEscape($h['changedByLabel']); ?><?php endif; ?>
                        </small>
                        <?php echo nl2br($this->htmlEscape($h['publicNote'])); ?>
                    </li>
                <?php endforeach; ?>
            </ul>
        </section>
    <?php endif; ?>

</div>
