<?php
/**
 * @var Mibizum_Sync_Block_Frontend_SmartItem $this
 *
 * Ficha pública de un Smart Item (ingrediente), maquetada al estilo de la página
 * original de MCC: cabecera con foto + título + estado, descripción amplia,
 * sustituto recomendado, y el HISTÓRICO de estados como un ROADMAP lateral
 * (columna 75/25). Los datos vienen de GET /api/v1/smart-items/{slug} del SaaS
 * Mibizum (statusLabel/statusBg/Fg, substatusLabel e historial con color por
 * estado ya enriquecidos en servidor). Estilo propio autocontenido (no depende
 * del CSS del tema). PHP 5.4-safe: sin operador `??`.
 */
$si = $this->getSmartItem();
if (!$si) {
    return;
}
$substituteUrl = $this->getSubstituteUrl();
$history       = $this->getPublicHistory();
$imageUrl      = !empty($si['imageUrl']) ? $si['imageUrl'] : '';
$statusBg      = !empty($si['statusBg']) ? $si['statusBg'] : '#ECECEC';
$statusFg      = !empty($si['statusFg']) ? $si['statusFg'] : '#333333';
?>
<style>
.mbz-si{--mbz-accent:#8b3a87;color:#2b2b2b;font-size:16px;line-height:1.7;max-width:1040px;margin:1.5rem auto;padding:0 1rem}
.mbz-si *{box-sizing:border-box}
.mbz-si__cols{display:flex;flex-wrap:wrap;gap:38px;align-items:flex-start}
.mbz-si__main{flex:1 1 380px;min-width:0}
.mbz-si__aside{flex:0 1 300px}
.mbz-si__head{display:flex;gap:20px;align-items:center;margin-bottom:1.6rem}
.mbz-si__photo{flex:0 0 auto;width:108px;height:108px;border-radius:14px;overflow:hidden;background:#f4f1f4;border:1px solid #e7e2e7;display:flex;align-items:center;justify-content:center}
.mbz-si__photo img{width:100%;height:100%;object-fit:cover;display:block}
.mbz-si__photo svg{width:46px;height:46px;color:#bca7ba}
.mbz-si__badges{margin-bottom:.5rem}
.mbz-si__status{display:inline-block;padding:.28em .9em;border-radius:999px;font-size:.85rem;font-weight:600;line-height:1.5}
.mbz-si__substatus{margin-left:.5rem;font-size:.9rem;color:#777}
.mbz-si__title{margin:0;font-size:2.1rem;line-height:1.12;color:#222}
.mbz-si__section{margin:0 0 2rem}
.mbz-si__section h2{font-size:1.3rem;margin:0 0 .6rem;color:#222}
.mbz-si__prose{line-height:1.75}
.mbz-si__sub{background:#faf6fa;border:1px solid #ecdfeb;border-radius:10px;padding:1.1rem 1.3rem}
.mbz-si__guide{background:#fff;border-left:4px solid var(--mbz-accent);border-radius:0;padding:.7rem 1rem;margin:.9rem 0}
.mbz-si__guide strong{display:block;margin-bottom:.25rem}
.mbz-si__btn{display:inline-block;margin-top:.6rem;padding:.6rem 1.2rem;background:var(--mbz-accent);color:#fff;text-decoration:none;border-radius:8px;font-size:.95rem}
.mbz-si__btn:hover{opacity:.92;color:#fff;text-decoration:none}
.mbz-si__sku{color:#888;font-size:.9rem}
.mbz-si__aside-title{font-size:1.15rem;margin:0 0 1.2rem;color:#222}
.mbz-si__road{list-style:none;margin:0;padding:0 0 0 26px;border-left:2px solid #e6e1e6}
.mbz-si__ms{position:relative;padding:0 0 1.5rem 6px}
.mbz-si__ms:last-child{padding-bottom:0}
.mbz-si__dot{position:absolute;left:-34px;top:3px;width:15px;height:15px;border-radius:50%;border:3px solid #fff;box-sizing:border-box}
.mbz-si__ms.is-now .mbz-si__dot{width:19px;height:19px;left:-36px;box-shadow:0 0 0 4px #f4f1f4}
.mbz-si__date{font-size:.8rem;color:#999;margin-bottom:.25rem}
.mbz-si__ms-status{display:inline-block;padding:.18em .7em;border-radius:999px;font-size:.78rem;font-weight:600;line-height:1.5}
.mbz-si__note{font-size:.92rem;color:#666;line-height:1.6;margin-top:.4rem}
.mbz-si__empty{color:#999;font-style:italic}
@media (max-width:760px){.mbz-si__title{font-size:1.7rem}.mbz-si__aside{flex-basis:100%}}
</style>

<div class="mbz-si">
  <div class="mbz-si__cols">

    <main class="mbz-si__main">
      <header class="mbz-si__head">
        <div class="mbz-si__photo">
          <?php if ($imageUrl): ?>
            <img src="<?php echo $this->htmlEscape($imageUrl); ?>" alt="<?php echo $this->htmlEscape($si['name']); ?>" loading="lazy" />
          <?php else: ?>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 21c.5-4.5 2.5-8 7-9"/><path d="M9 18c6 0 10-4 10-11V4h-3C8 4 5 9 5 14c0 1.5.4 2.8 1 4"/></svg>
          <?php endif; ?>
        </div>
        <div class="mbz-si__heir">
          <div class="mbz-si__badges">
            <?php if (!empty($si['statusLabel'])): ?>
              <span class="mbz-si__status" style="background:<?php echo $this->htmlEscape($statusBg); ?>;color:<?php echo $this->htmlEscape($statusFg); ?>;"><?php echo $this->htmlEscape($si['statusLabel']); ?></span>
            <?php endif; ?>
            <?php if (!empty($si['substatusLabel'])): ?>
              <span class="mbz-si__substatus">· <?php echo $this->htmlEscape($si['substatusLabel']); ?></span>
            <?php endif; ?>
          </div>
          <h1 class="mbz-si__title"><?php echo $this->htmlEscape($si['name']); ?></h1>
        </div>
      </header>

      <?php if (!empty($si['description'])): ?>
        <section class="mbz-si__section">
          <h2><?php echo $this->__('¿Qué es?'); ?></h2>
          <div class="mbz-si__prose"><?php echo nl2br($this->htmlEscape($si['description'])); ?></div>
        </section>
      <?php endif; ?>

      <?php if (!empty($si['hasSubstitute'])): ?>
        <section class="mbz-si__section mbz-si__sub">
          <h2><?php echo $this->__('Sustituto recomendado'); ?></h2>
          <?php if (!empty($si['substituteExtendedDescription'])): ?>
            <div class="mbz-si__prose"><?php echo nl2br($this->htmlEscape($si['substituteExtendedDescription'])); ?></div>
          <?php endif; ?>
          <?php if (!empty($si['substituteFormulationGuide'])): ?>
            <div class="mbz-si__guide">
              <strong><?php echo $this->__('Cómo formularlo'); ?></strong>
              <div><?php echo nl2br($this->htmlEscape($si['substituteFormulationGuide'])); ?></div>
            </div>
          <?php endif; ?>
          <?php if ($substituteUrl): ?>
            <a class="mbz-si__btn" href="<?php echo $this->htmlEscape($substituteUrl); ?>"><?php echo $this->__('Ver en la tienda'); ?> &rarr;</a>
          <?php elseif (!empty($si['substituteProductId'])): ?>
            <p class="mbz-si__sku"><?php echo $this->__('Sustituto'); ?>: <code><?php echo $this->htmlEscape($si['substituteProductId']); ?></code></p>
          <?php endif; ?>
        </section>
      <?php endif; ?>
    </main>

    <aside class="mbz-si__aside">
      <h2 class="mbz-si__aside-title"><?php echo $this->__('Recorrido del ingrediente'); ?></h2>
      <?php if (count($history) > 0): ?>
        <ol class="mbz-si__road">
          <?php foreach ($history as $i => $h): ?>
            <?php
              $hBg = !empty($h['statusBg']) ? $h['statusBg'] : '#bbbbbb';
              $hFg = !empty($h['statusFg']) ? $h['statusFg'] : '#333333';
              $ts  = !empty($h['changedAt']) ? strtotime($h['changedAt']) : false;
            ?>
            <li class="mbz-si__ms<?php echo $i === 0 ? ' is-now' : ''; ?>">
              <span class="mbz-si__dot" style="background:<?php echo $this->htmlEscape($hBg); ?>;"></span>
              <div class="mbz-si__date">
                <?php echo $ts ? $this->htmlEscape(date('d/m/Y', $ts)) : ''; ?><?php if ($i === 0): ?> · <?php echo $this->__('estado actual'); ?><?php endif; ?>
              </div>
              <?php if (!empty($h['statusLabel'])): ?>
                <span class="mbz-si__ms-status" style="background:<?php echo $this->htmlEscape($hBg); ?>;color:<?php echo $this->htmlEscape($hFg); ?>;"><?php echo $this->htmlEscape($h['statusLabel']); ?></span>
              <?php endif; ?>
              <?php if (!empty($h['publicNote'])): ?>
                <div class="mbz-si__note"><?php echo nl2br($this->htmlEscape($h['publicNote'])); ?></div>
              <?php endif; ?>
            </li>
          <?php endforeach; ?>
        </ol>
      <?php else: ?>
        <p class="mbz-si__empty"><?php echo $this->__('Sin movimientos todavía.'); ?></p>
      <?php endif; ?>
    </aside>

  </div>
</div>
