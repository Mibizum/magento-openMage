/**
 * First-run install wizard.
 *
 * Two render modes (decided by the block):
 *   - banner:  a slim strip offering to resume (state=dismissed).
 *   - overlay: the full guided modal (states pending..studio).
 *
 * The account / key-provisioning / Widget-Studio steps are a hosted iframe
 * (app.mibizum.io). The iframe posts the issued keys back; the parent forwards
 * them to the native WizardController (encrypted). Indexing + widget are native.
 * Strict postMessage origin checks on both sides. Fallback: a "configure
 * manually" link if the iframe is unreachable.
 *
 * @var Mibizum_Sync_Block_Adminhtml_Wizard $this
 */
$mode = $this->getMode();
if ($mode === '') { return; }

$js = function ($v) { return json_encode($v, JSON_UNESCAPED_SLASHES); };
?>
<?php if ($mode === Mibizum_Sync_Block_Adminhtml_Wizard::MODE_BANNER): ?>
<div id="mbz-wiz-banner" style="margin:8px 0; padding:10px 16px; border-radius:4px; background:#eef5fc; border:1px solid #bcdcf5; color:#1f4e7a; display:flex; align-items:center; gap:14px;">
    <span style="font-weight:600;"><?php echo $this->__('Finish connecting your store to Mibizum search.'); ?></span>
    <button type="button" id="mbz-wiz-resume" class="scalable"><span><?php echo $this->__('Resume setup'); ?></span></button>
</div>
<script type="text/javascript">
//<![CDATA[
(function () {
    var b = document.getElementById('mbz-wiz-resume');
    if (!b) { return; }
    b.addEventListener('click', function () {
        new Ajax.Request(<?php echo $js($this->getStateUrl()); ?>, {
            method: 'post',
            parameters: { form_key: <?php echo $js($this->getFormKey()); ?>, state: 'intro' },
            requestHeaders: { 'X-Requested-With': 'XMLHttpRequest' },
            onComplete: function () { window.location.reload(); }
        });
    });
})();
//]]>
</script>
<?php return; endif; ?>

