<script type="text/javascript">
//<![CDATA[
(function () {
    var CFG = {
        state:        <?php echo $js($this->getState()); ?>,
        onboardingUrl:<?php echo $js($this->getOnboardingUrl()); ?>,
        mibizumOrigin:<?php echo $js($this->getMibizumOrigin()); ?>,
        saveKeysUrl:  <?php echo $js($this->getSaveKeysUrl()); ?>,
        widgetUrl:    <?php echo $js($this->getWidgetUrl()); ?>,
        stateUrl:     <?php echo $js($this->getStateUrl()); ?>,
        dismissUrl:   <?php echo $js($this->getDismissUrl()); ?>,
        reindexUrl:   <?php echo $js($this->getFullReindexUrl()); ?>,
        statsUrl:     <?php echo $js($this->getStatsUrl()); ?>,
        formKey:      <?php echo $js($this->getFormKey()); ?>
    };
    var STEP_FOR_STATE = {
        pending:'intro', intro:'intro', account:'connect', provisioning:'connect',
        indexing:'indexing', widget:'widget', studio:'studio', done:'done'
    };
    var ORDER = ['intro','connect','indexing','widget'];

    function $(id){ return document.getElementById(id); }
    function root(){ return $('mbz-wiz'); }
    function post(url, params, cb){
        var p = Object.assign({ form_key: CFG.formKey }, params || {});
        new Ajax.Request(url, {
            method:'post', parameters:p,
            requestHeaders:{ 'X-Requested-With':'XMLHttpRequest' },
            onSuccess:function(r){ var d=null; try{ d=r.responseJSON||JSON.parse(r.responseText);}catch(e){} cb&&cb(d,true); },
            onFailure:function(r){ cb&&cb(null,false,r); }
        });
    }
    function msg(text, ok){
        var el=$('mbz-wiz-msg'); if(!el){return;}
        el.style.background = ok ? '#e6f4ec' : '#fdecea';
        el.style.color      = ok ? '#2f855a' : '#a4342b';
        el.textContent=text; el.style.display='block';
        if(el._t){clearTimeout(el._t);} el._t=setTimeout(function(){el.style.display='none';},8000);
    }

    function showStep(step){
        var steps = root().querySelectorAll('.mbz-wiz-step');
        for (var i=0;i<steps.length;i++){ steps[i].style.display = (steps[i].getAttribute('data-step')===step)?'block':'none'; }
        // step dots
        var dots = root().querySelectorAll('.mbz-wiz-steps li');
        var idx = ORDER.indexOf(step);
        for (var j=0;j<dots.length;j++){
            var key = dots[j].getAttribute('data-dot');
            var di  = ORDER.indexOf(key);
            dots[j].className = (di<idx) ? 'is-done' : (di===idx ? 'is-active' : '');
        }
        if (step==='connect'){ loadFrame('mbz-wiz-frame', CFG.onboardingUrl); }
        if (step==='studio'){ loadFrame('mbz-wiz-studio-frame', CFG.onboardingUrl + (CFG.onboardingUrl.indexOf('?')>=0?'&':'?') + 'step=studio'); }
        if (step==='indexing'){ startIndexing(); }
    }

    var _frameTimer=null;
    function loadFrame(id, url){
        var f=$(id); if(!f){return;}
        if (!CFG.mibizumOrigin || !url){ showFallback(); return; }
        f.src = url;
        // If the SaaS page is unreachable we never get a postMessage; surface a
        // manual-config fallback after a grace period (only for the main frame).
        if (id==='mbz-wiz-frame'){
            if(_frameTimer){clearTimeout(_frameTimer);}
            _frameTimer = setTimeout(function(){ /* keep iframe; fallback link already available below it on error */ }, 12000);
            f.onerror = showFallback;
        }
    }
    function showFallback(){ var fb=$('mbz-wiz-frame-fallback'); if(fb){fb.style.display='flex';} }

    // ---- postMessage from the hosted onboarding iframe ----
    window.addEventListener('message', function (ev) {
        if (!CFG.mibizumOrigin || ev.origin !== CFG.mibizumOrigin) { return; } // strict origin check
        var d = ev.data || {};
        if (!d || typeof d.type !== 'string') { return; }
        if (d.type === 'mibizum:keys') {
            post(CFG.saveKeysUrl, {
                indexer_key: d.indexerKey || '',
                search_key:  d.searchKey || '',
                data_source_slug: d.dataSourceSlug || ''
            }, function (res, ok) {
                if (ok && res && res.success) {
                    if (d.widgetSnippet) { var t=$('mbz-wiz-snippet'); if(t){ t.value=d.widgetSnippet; } }
                    showStep('indexing');
                } else { msg((res && res.message) || <?php echo $js($this->__('Could not save the connection.')); ?>, false); }
            });
        } else if (d.type === 'mibizum:cancel') {
            later();
        } else if (d.type === 'mibizum:studioDone') {
            goDone();
        }
    }, false);

    // ---- indexing (native, reuses the Reindex endpoints) ----
    var _poll=null, _started=false;
    function startIndexing(){
        if (_started) { return; } _started = true;
        // Indeterminate animated bar (a "loader") while the catalog is pushed —
        // a fixed % would be misleading since the drain is synchronous.
        var bar=$('mbz-wiz-bar'); if(bar){ bar.style.width=''; bar.className='mbz-wiz-bar mbz-ind'; }
        pollStats();
        _poll = setInterval(pollStats, 2500);
        post(CFG.reindexUrl, {}, function(){ pollStats(); finishIndexing(); });
    }
    function pollStats(){
        new Ajax.Request(CFG.statsUrl, { method:'get', onSuccess:function(r){
            var d=null; try{ d=r.responseJSON||JSON.parse(r.responseText);}catch(e){}
            if(!d){return;}
            var docs = (d.index && d.index.numberOfDocuments) ? Number(d.index.numberOfDocuments) : 0;
            var pend = (d.queue && d.queue.pending) ? Number(d.queue.pending) : 0;
            var dEl=$('mbz-wiz-docs'), pEl=$('mbz-wiz-pending');
            if(dEl){dEl.textContent=docs.toLocaleString('en-US');} if(pEl){pEl.textContent=pend.toLocaleString('en-US');}
            if (pend===0 && docs>0) { finishIndexing(); }
        }});
    }
    function finishIndexing(){
        if(_poll){clearInterval(_poll); _poll=null;}
        var bar=$('mbz-wiz-bar'); if(bar){ bar.className='mbz-wiz-bar'; bar.style.width='100%'; }
        var b=$('mbz-wiz-index-next'); if(b){ b.disabled=false; }
    }

    // ---- transitions ----
    function setState(s, cb){ post(CFG.stateUrl, { state:s }, cb); }
    function later(){ post(CFG.dismissUrl, {}, function(){ hide(); }); }
    // Studio step "Finish"/launch -> show the success screen (big check); persist done.
    function goDone(){ setState('done'); showStep('done'); }
    function finish(){ setState('done', function(){ hide(); }); }
    function hide(){ var r=root(); if(r){ r.parentNode && r.parentNode.removeChild(r); } }

    function bind(id, fn){ var e=$(id); if(e){ e.addEventListener('click', fn); } }

    document.observe('dom:loaded', function () {
        if (!root()) { return; }
        bind('mbz-wiz-later', later);
        bind('mbz-wiz-later2', later);
        bind('mbz-wiz-go', function(){ setState('account'); showStep('connect'); });
        bind('mbz-wiz-index-next', function(){ setState('widget'); showStep('widget'); });
        bind('mbz-wiz-widget-save', function(){
            var t=$('mbz-wiz-snippet'); var snip = t ? t.value : '';
            post(CFG.widgetUrl, { widget_snippet: snip }, function(res, ok){
                if (ok && res && res.success) { showStep('studio'); }
                else { msg((res && res.message) || <?php echo $js($this->__('Could not enable the widget.')); ?>, false); }
            });
        });
        bind('mbz-wiz-widget-skip', function(){ setState('studio'); showStep('studio'); });
        bind('mbz-wiz-finish', goDone);
        bind('mbz-wiz-close', finish);

        showStep(STEP_FOR_STATE[CFG.state] || 'intro');
    });
})();
//]]>
</script>
