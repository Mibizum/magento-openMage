  .mibizum-ab__fa-clear { background: #eee; border: 1px solid #ccc; border-radius: 4px; padding: 0 0.6rem; cursor: pointer; font-size: 1rem; color: #555 !important; }
  .mibizum-ab__fa-clear:hover { background: #fbe5e5; color: #d63d3d !important; border-color: #d63d3d; }
  .mibizum-ab__fa-current { margin-top: 0.5rem; font-size: 0.85rem; color: #555 !important; min-height: 1.4em; }
  .mibizum-ab__fa-current code { background: #f4f4f4; padding: 0.1rem 0.4rem; border-radius: 3px; }
  .mibizum-ab__fa-current i.fa { margin-left: 0.3rem; color: #1e9c3c !important; }
  .mibizum-ab__fa-suggestions { margin-top: 0.5rem; display: none; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 0.3rem; max-height: 320px; overflow-y: auto; padding: 0.4rem; border: 1px solid #ccc; border-radius: 4px; background: #fafafa; }
  .mibizum-ab__fa-suggestions.is-open { display: grid; }
  .mibizum-ab__fa-item { display: flex; align-items: center; gap: 0.4rem; background: #fff; border: 1px solid #ddd; border-radius: 4px; padding: 0.4rem 0.5rem; cursor: pointer; font-size: 0.78rem; color: #333 !important; text-align: left; line-height: 1.2; }
  .mibizum-ab__fa-item:hover { background: #e8f5e9; border-color: #1e9c3c; }
  .mibizum-ab__fa-item i.fa { font-size: 1.1rem; color: #1e9c3c !important; flex: 0 0 auto; width: 1.2em; text-align: center; }
  .mibizum-ab__fa-item span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .mibizum-ab__fa-empty { grid-column: 1 / -1; text-align: center; color: #888 !important; padding: 1rem; font-size: 0.85rem; }
</style>

<script>
(function () {
  'use strict';
  var $ = function (id) { return document.getElementById(id); };
  var root = document.querySelector('.mibizum-ab');
  if (!root) return;

  var uploadUrl       = root.getAttribute('data-upload-url');
  var paletteUrl      = root.getAttribute('data-palette-url');
  var suggestTextUrl  = root.getAttribute('data-suggest-text-url');

  function setupPicker(hiddenId, containerId, btnSelector) {
    var hidden = $(hiddenId);
    var btns = root.querySelectorAll('#' + containerId + ' ' + btnSelector);
    function setVal(v) {
      hidden.value = v;
      btns.forEach(function (b) { b.classList.toggle('is-selected', b.getAttribute('data-val') === v); });
    }
    btns.forEach(function (b) {
      b.addEventListener('click', function () { setVal(b.getAttribute('data-val')); applyShapeRules(); syncIconPreview(); });
    });
    setVal(hidden.value);
    return setVal;
  }
  setupPicker('mibizum-ab-position', 'mibizum-ab-position-picker', '.mibizum-ab__pos');
  var setShape   = setupPicker('mibizum-ab-shape',   'mibizum-ab-shape-picker',   '.mibizum-ab__btn');
  var setDisplay = setupPicker('mibizum-ab-display', 'mibizum-ab-display-picker', '.mibizum-ab__btn');

  function applyShapeRules() {
    if ($('mibizum-ab-shape').value === 'circle') {
      setDisplay('icon_only');
      $('mibizum-ab-display-row').style.opacity = '0.5';
      $('mibizum-ab-shape-help').textContent = '<?php echo Mage::helper('core')->jsQuoteEscape($this->__('In a circle the text does not fit (icon only, forced).')) ?>';
    } else {
      $('mibizum-ab-display-row').style.opacity = '';
      $('mibizum-ab-shape-help').textContent = '';
    }
  }
  applyShapeRules();

  // ---- COLOR + TEXT COLOR (mirror of the nature form) ----
  var $colorHidden     = $('mibizum-ab-color');
  var $textColorHidden = $('mibizum-ab-text-color');
  var $colorToggle     = $('mibizum-ab-color-toggle');
  var $colorDropdown   = $('mibizum-ab-color-dropdown');
  var $colorChip       = $('mibizum-ab-color-chip');
  var $colorName       = $('mibizum-ab-color-name');
  var palette = [];

  var $textColorPicker  = $('mibizum-ab-textcolor-picker');
  var $textColorHex     = $('mibizum-ab-textcolor-hex');
  var $textColorPreview = $('mibizum-ab-textcolor-preview');
  var $textColorAuto    = $('mibizum-ab-textcolor-auto');
  var textColorManuallyTouched = false;

  function setTextColor(hex, fromAuto) {
    if (!/^#[0-9A-Fa-f]{6}$/.test(hex)) return;
    hex = hex.toUpperCase();
    $textColorHidden.value = hex;
    $textColorPicker.value = hex;
    $textColorHex.value = hex;
    syncTextColorPreview();
    syncIconPreview();
    if (!fromAuto) textColorManuallyTouched = true;
  }
  function syncTextColorPreview() {
    if (!$textColorPreview) return;
    $textColorPreview.style.background = $colorHidden.value || '#1e9c3c';
    $textColorPreview.style.color = $textColorHidden.value || '#fff';
  }
  function autoSuggestTextColor(hex) {
    var bg = hex || $colorHidden.value;
    if (!/^#[0-9A-F]{6}$/i.test(bg)) return;
    fetch(suggestTextUrl + (suggestTextUrl.indexOf('?') !== -1 ? '&' : '?') + 'color_hex=' + encodeURIComponent(bg), { credentials: 'same-origin' })
      .then(function (r) { return r.ok ? r.json() : { text_color_hex: '#FFFFFF' }; })
      .then(function (data) { setTextColor(data.text_color_hex || '#FFFFFF', true); });
  }
  $textColorPicker.addEventListener('input', function () { setTextColor($textColorPicker.value); });
  $textColorHex.addEventListener('input', function () {
    if (/^#[0-9A-Fa-f]{6}$/.test($textColorHex.value)) setTextColor($textColorHex.value);
  });
  $textColorAuto.addEventListener('click', function () {
    textColorManuallyTouched = false;
    autoSuggestTextColor();
  });

  function selectColor(hex, textHex, label) {
    $colorHidden.value = hex;
    $colorChip.style.background = hex;
    $colorName.textContent = label || hex;
    $colorDropdown.hidden = true;
    if (textHex && !textColorManuallyTouched) setTextColor(textHex, true);
    else if (!textColorManuallyTouched) autoSuggestTextColor(hex);
    else syncTextColorPreview();
    syncIconPreview();
  }
  function renderPalette() {
    $colorDropdown.innerHTML = '';
    if (palette.length === 0) {
      $colorDropdown.innerHTML = '<div class="mibizum-ab__color-empty"><?php echo Mage::helper('core')->jsQuoteEscape($this->__('No colors in use yet. Choose a new one.')) ?></div>';
      return;
    }
    palette.forEach(function (c) {
      var item = document.createElement('div');
      item.className = 'mibizum-ab__color-item';
      var chip = document.createElement('span'); chip.className = 'chip'; chip.style.background = c.color_hex;
      var name = document.createElement('span'); name.className = 'name'; name.textContent = c.color_hex;
      var usedBy = document.createElement('span'); usedBy.className = 'used-by';
      usedBy.textContent = c.used_by && c.used_by.length ? '· ' + c.used_by.slice(0, 2).join(', ') + (c.used_by.length > 2 ? '…' : '') : '';
      item.appendChild(chip); item.appendChild(name); item.appendChild(usedBy);
      var label = c.used_by && c.used_by.length ? c.used_by[0] : c.color_hex;
      item.addEventListener('click', function () { selectColor(c.color_hex, c.text_color_hex, label); });
      $colorDropdown.appendChild(item);
    });
  }
  function loadPalette() {
    fetch(paletteUrl, { credentials: 'same-origin' })
      .then(function (r) { return r.ok ? r.json() : []; })
      .then(function (data) {
        palette = data || [];
        renderPalette();
        var cur = palette.filter(function (c) { return (c.color_hex || '').toUpperCase() === ($colorHidden.value || '').toUpperCase(); })[0];
        $colorChip.style.background = $colorHidden.value;
        $colorName.textContent = cur && cur.used_by && cur.used_by.length ? cur.used_by[0] : ($colorHidden.value || '-');
      })
      .catch(function () {});
  }
  loadPalette();

  $colorToggle.addEventListener('click', function () { $colorDropdown.hidden = !$colorDropdown.hidden; });
  document.addEventListener('click', function (e) {
    if (!$colorToggle.contains(e.target) && !$colorDropdown.contains(e.target)) $colorDropdown.hidden = true;
  });

  var $newPicker = $('mibizum-ab-color-newpicker');
  var $newHex    = $('mibizum-ab-color-newhex');
  $newPicker.addEventListener('input', function () { $newHex.value = $newPicker.value.toUpperCase(); });
  $newHex.addEventListener('input', function () {
    if (/^#[0-9A-Fa-f]{6}$/.test($newHex.value)) $newPicker.value = $newHex.value;
  });
  $('mibizum-ab-color-apply').addEventListener('click', function () {
    var hex = ($newHex.value || $newPicker.value).toUpperCase();
    if (!/^#[0-9A-F]{6}$/.test(hex)) { alert('<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Enter a valid #RRGGBB color.')) ?>'); return; }
    fetch(suggestTextUrl + (suggestTextUrl.indexOf('?') !== -1 ? '&' : '?') + 'color_hex=' + encodeURIComponent(hex), { credentials: 'same-origin' })
      .then(function (r) { return r.ok ? r.json() : { color_hex: hex, text_color_hex: '#FFFFFF' }; })
      .then(function (data) { selectColor(data.color_hex, data.text_color_hex, hex); });
  });

  // ---- ICON DROPZONE ----
  var $dropzone = $('mibizum-ab-dropzone');
  var $fileInput = $dropzone.querySelector('input[type=file]');
  var $pick = $dropzone.querySelector('.mibizum-ab__pick');
  var $uploadStatus = $('mibizum-ab-upload-status');
  var $svgTextarea = $('mibizum-ab-svg-textarea');
  var $svgHidden = $('mibizum-ab-icon-svg');
  var $urlHidden = $('mibizum-ab-icon-url');
  var $faHidden  = $('mibizum-ab-icon-fa');

  $pick.addEventListener('click', function (e) { e.preventDefault(); $fileInput.click(); });
  $dropzone.addEventListener('click', function (e) { if (e.target.closest('a, input')) return; $fileInput.click(); });
  ['dragenter', 'dragover'].forEach(function (ev) {
    $dropzone.addEventListener(ev, function (e) { e.preventDefault(); e.stopPropagation(); $dropzone.classList.add('is-active'); });
  });
  ['dragleave', 'drop'].forEach(function (ev) {
    $dropzone.addEventListener(ev, function (e) { e.preventDefault(); e.stopPropagation(); $dropzone.classList.remove('is-active'); });
  });
  $dropzone.addEventListener('drop', function (e) { if (e.dataTransfer && e.dataTransfer.files.length > 0) uploadIcon(e.dataTransfer.files[0]); });
  $fileInput.addEventListener('change', function () { if ($fileInput.files.length > 0) uploadIcon($fileInput.files[0]); });

  function uploadIcon(file) {
    if (file.size > 512 * 1024) { setUploadStatus('<?php echo Mage::helper('core')->jsQuoteEscape($this->__('File too large')) ?> (' + Math.round(file.size/1024) + ' KB).', true); return; }
    setUploadStatus('<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Uploading')) ?> ' + file.name + '…', false);
    var fd = new FormData();
    fd.append('icon_file', file);
    if (typeof FORM_KEY !== 'undefined') fd.append('form_key', FORM_KEY);
    fetch(uploadUrl, { method: 'POST', credentials: 'same-origin', body: fd })
      .then(function (r) { return r.text().then(function (t) { return { status: r.status, text: t }; }); })
      .then(function (resp) {
        var data = null; try { data = JSON.parse(resp.text); } catch (e) { setUploadStatus('<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Non-JSON response.')) ?>', true); return; }
        if (!data.ok) { setUploadStatus('<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Error:')) ?> ' + (data.error || ''), true); return; }
        $urlHidden.value = data.url;
        var ext = (data.name || '').split('.').pop().toLowerCase();
        if (ext !== 'svg') { $svgTextarea.value = ''; $svgHidden.value = ''; }
        ensureIconVisible();
        syncIconPreview();
        setUploadStatus('✓ <?php echo Mage::helper('core')->jsQuoteEscape($this->__('Uploaded:')) ?> ' + data.name, false);
      })
      .catch(function () { setUploadStatus('<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Network error.')) ?>', true); });
  }
  function setUploadStatus(msg, isErr) { $uploadStatus.textContent = msg || ''; $uploadStatus.style.color = isErr ? '#d63d3d' : '#1e9c3c'; }

  /** Auto-switch display to "Icon + text" if it was on "Text only" when an icon is chosen. */
  function ensureIconVisible() {
    var $disp = $('mibizum-ab-display');
    if ($disp && $disp.value === 'text_only') {
      setDisplay('icon_and_text');
    }
  }

  $svgTextarea.addEventListener('input', function () {
    $svgHidden.value = $svgTextarea.value;
    if ($svgTextarea.value.trim() !== '') ensureIconVisible();
    syncIconPreview();
  });

  function syncIconPreview() {
    var $preview = $('mibizum-ab-icon-preview');
    if (!$preview) return;
    var color = $colorHidden.value || '#1e9c3c';
    var text  = $textColorHidden.value || '#fff';
    var shape = $('mibizum-ab-shape').value;
    $preview.style.background = color;
    $preview.style.color = text;
    if (shape === 'circle') $preview.style.borderRadius = '50%';
    else if (shape === 'square_rounded') $preview.style.borderRadius = '12px';
    else $preview.style.borderRadius = '999px';

    var svg = $svgHidden.value && $svgHidden.value.trim();
    var url = $urlHidden.value && $urlHidden.value.trim();
    var fa  = $faHidden && $faHidden.value && $faHidden.value.trim();
    // Order: FA > SVG > URL (consistent with the frontend).
    if (fa) {
      $preview.innerHTML = '<i class="fa ' + fa.replace(/"/g, '') + '" style="font-size:36px;line-height:1;"></i>';
    } else if (svg) {
      $preview.innerHTML = svg;
      var inner = $preview.querySelector('svg');
      if (inner) { inner.style.width = '48px'; inner.style.height = '48px'; }
    } else if (url) {
      $preview.innerHTML = '<img src="' + url.replace(/"/g, '&quot;') + '" alt="">';
    } else {
      $preview.innerHTML = '<span style="font-size:1.6rem;">?</span>';
    }
  }
  syncIconPreview();
  syncTextColorPreview();

  // -------- FONT AWESOME PICKER --------
  var $faSearch  = $('mibizum-ab-fa-search');
  var $faSuggest = $('mibizum-ab-fa-suggestions');
  var $faClear   = $('mibizum-ab-fa-clear');
  var $faCurrent = $('mibizum-ab-fa-current');
  var faList     = <?php echo json_encode(array_values($faIcons), JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT); ?>;
  if (!Array.isArray(faList)) faList = [];
  var FA_MAX = 60;

  function renderFaCurrent(cls) {
    if (!$faCurrent) return;
    $faCurrent.innerHTML = cls
      ? '<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Selected:')) ?> <code>' + cls + '</code> <i class="fa ' + cls + '" style="font-size:1.4rem;vertical-align:middle;"></i>'
      : '';
  }
  function renderFaSuggestions(query) {
    if (!$faSuggest) return;
    $faSuggest.innerHTML = '';
    var q = (query || '').toLowerCase().trim();
    if (q.length < 2) { $faSuggest.classList.remove('is-open'); return; }
    var matches = [];
    for (var i = 0; i < faList.length && matches.length < FA_MAX; i++) {
      if (faList[i].indexOf(q) !== -1) matches.push(faList[i]);
    }
    if (matches.length === 0) {
      $faSuggest.innerHTML = '<div class="mibizum-ab__fa-empty"><?php echo Mage::helper('core')->jsQuoteEscape($this->__('No matches.')) ?></div>';
      $faSuggest.classList.add('is-open');
      return;
    }
    matches.forEach(function (cls) {
      var item = document.createElement('button');
      item.type = 'button';
      item.className = 'mibizum-ab__fa-item';
      item.title = cls;
      item.innerHTML = '<i class="fa ' + cls + '"></i><span>' + cls + '</span>';
      item.addEventListener('click', function () { selectFa(cls); });
      $faSuggest.appendChild(item);
    });
    $faSuggest.classList.add('is-open');
  }
  function selectFa(cls) {
    if (!$faHidden) return;
    $faHidden.value = cls;
    if ($faSearch) $faSearch.value = '';
    if ($faSuggest) { $faSuggest.innerHTML = ''; $faSuggest.classList.remove('is-open'); }
    $svgHidden.value = '';
    $urlHidden.value = '';
    if ($svgTextarea) $svgTextarea.value = '';
    ensureIconVisible();
    renderFaCurrent(cls);
    syncIconPreview();
  }
  if ($faSearch) {
    $faSearch.addEventListener('input', function () { renderFaSuggestions($faSearch.value); });
    $faSearch.addEventListener('focus', function () { if ($faSearch.value.length >= 2) $faSuggest.classList.add('is-open'); });
  }
  if ($faClear) {
    $faClear.addEventListener('click', function () {
      if ($faHidden) $faHidden.value = '';
      renderFaCurrent('');
      syncIconPreview();
    });
  }
  document.addEventListener('click', function (e) {
    if ($faSuggest && !$faSuggest.contains(e.target) && e.target !== $faSearch) {
      $faSuggest.classList.remove('is-open');
    }
  });

  // (The attribute_code search moved to the Form as the reusable
  //  mibizum-searchable-select widget in AJAX mode. Endpoint: searchAttributes.)

  // (The scope category picker moved to the reusable
  //  mibizum-multiselect-table widget - it emits the same attribute_categories_json JSON.)
})();
</script>
