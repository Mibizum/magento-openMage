$faListPath = Mage::getBaseDir('app') . DS . 'code' . DS . 'local' . DS . 'Mibizum' . DS . 'Search' . DS . 'etc' . DS . 'fa47-icons.txt';
$faIcons = is_readable($faListPath) ? array_values(array_filter(array_map('trim', file($faListPath)))) : array();
$faCssUrl = Mage::getBaseUrl(Mage_Core_Model_Store::URL_TYPE_SKIN) . 'frontend/base/default/css/plumrocket/pramp/font-awesome.min.css';
