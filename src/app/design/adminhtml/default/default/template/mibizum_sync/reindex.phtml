                    <td style="padding:6px 10px; border-bottom:1px solid #eee; font-family:monospace;"><?php echo $c['slug'] !== '' ? $this->escapeHtml($c['slug']) : '<span style="color:#bbb;">&mdash;</span>'; ?></td>
                    <td style="padding:6px 10px; border-bottom:1px solid #eee; text-align:right;">
                        <span style="padding:2px 8px; border-radius:10px; font-weight:600; color:<?php echo $col; ?>; background:<?php echo $bg; ?>;"><?php echo $this->escapeHtml($this->getStatusLabel($c['status'])); ?></span>
