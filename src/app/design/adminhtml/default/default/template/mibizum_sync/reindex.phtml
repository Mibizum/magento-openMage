    <?php if ($debug): ?>
    <div style="margin-top:20px;">
        <h5 style="margin:0 0 6px; color:#888;"><?php echo $this->__('Raw status (debug mode)'); ?></h5>
        <div id="mibizum_reindex_raw" style="background:#f4f4f4; padding:10px; font-family:monospace; white-space:pre; border:1px solid #ddd; font-size:11px; max-height:260px; overflow:auto;"><?php echo $this->__('Press "Refresh status".'); ?></div>
    </div>
    <?php endif; ?>

</div>

<script type="text/javascript">
//<![CDATA[
(function () {
    var STATS_URL    = <?php echo json_encode($this->getStatsUrl()); ?>;
    var FULL_URL     = <?php echo json_encode($this->getFullReindexUrl()); ?>;
    var PROGRESS_URL = <?php echo json_encode($this->getProgressUrl()); ?>;
    var FORM_KEY     = <?php echo json_encode(Mage::getSingleton('core/session')->getFormKey()); ?>;
    var DEBUG        = <?php echo $debug ? 'true' : 'false'; ?>;
    var RESUME       = <?php echo $resumeRunning ? 'true' : 'false'; ?>;

    var T = {
        indexing:   <?php echo json_encode($this->__('Indexing…')); ?>,
        pending:    <?php echo json_encode($this->__('pending')); ?>,
        done:       <?php echo json_encode($this->__('Reindex complete: %s product(s) indexed.')); ?>,
        doneErrors: <?php echo json_encode($this->__('Reindex finished with %s error(s). Check the log.')); ?>,
        httpErr:    <?php echo json_encode($this->__('HTTP error')); ?>,
        genErr:     <?php echo json_encode($this->__('Error.')); ?>
    };

    var reindexTotal = 0;     // products queued for the current run
    var polling      = false; // a progress loop is active
    var failStreak   = 0;     // consecutive transient poll failures

    function $id(id) { return document.getElementById(id); }

    function showMsg(text, ok) {
        var el = $id('mibizum_reindex_msg');
        if (!el) { return; }
        el.style.background = ok ? '#dff0d8' : '#f2dede';
        el.style.color      = ok ? '#3c763d' : '#a94442';
        el.style.border     = '1px solid ' + (ok ? '#d6e9c6' : '#ebccd1');
        el.textContent      = text;
        el.style.display    = 'block';
        if (el._t) { clearTimeout(el._t); }
        el._t = setTimeout(function () { el.style.display = 'none'; }, 9000);
    }

    function applyStats(data) {
        if (!data) { return; }
        if (data.index && typeof data.index.numberOfDocuments !== 'undefined') {
            var d = $id('mibizum_reindex_docs');
            if (d) { d.textContent = Number(data.index.numberOfDocuments).toLocaleString('en-US'); }
        }
        if (data.queue) {
            var pending = Number(data.queue.pending || 0);
            var locked  = Number(data.queue.locked || 0);
            var pEl = $id('mibizum_reindex_pending');
            if (pEl) { pEl.textContent = pending; }
            var zEl = $id('mibizum_reindex_pending_zero');
            if (zEl) { zEl.style.display = pending > 0 ? 'none' : ''; }
            var lEl = $id('mibizum_reindex_locked');
            if (lEl) {
                lEl.style.display = locked > 0 ? '' : 'none';
                var b = lEl.querySelector('b.v');
                if (b) { b.textContent = locked; }
            }
        }
        if (DEBUG) {
            var raw = $id('mibizum_reindex_raw');
            if (raw) {
                raw.innerHTML = JSON.stringify(data, null, 2)
                    .replace(/&/g, '&amp;').replace(/</g, '&lt;');
            }
        }
    }

    function refreshStats(cb) {
        new Ajax.Request(STATS_URL, {
            method: 'get',
            onSuccess: function (resp) {
                var data = null;
                try { data = resp.responseJSON || JSON.parse(resp.responseText); } catch (e) {}
                applyStats(data);
                if (cb) { cb(); }
            },
            onFailure: function () { showMsg('<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Could not read the index status.')); ?>', false); if (cb) { cb(); } }
        });
    }

    function runAction(btn) {
        var url     = btn.getAttribute('data-mibizum-url');
        var reload  = btn.getAttribute('data-mibizum-reload') === '1';
        var confirm = btn.getAttribute('data-mibizum-confirm');
        if (!url) { return; }
        if (confirm) {
            // {pending} is replaced with the current on-screen counter
            // (reflects the last "Refresh status", not the rendered value).
            var pEl = $id('mibizum_reindex_pending');
            var pending = pEl ? (pEl.textContent || '0').replace(/[^0-9]/g, '') : '0';
            confirm = confirm.replace('{pending}', pending || '0');
            if (!window.confirm(confirm)) { return; }
        }

        var span  = btn.getElementsByTagName('span')[0];
        var label = span ? span.textContent : '';
        if (span) { span.textContent = '⏳ ' + label; }
        btn.disabled = true;

        new Ajax.Request(url, {
            method: 'post',
            parameters: { form_key: FORM_KEY },
            requestHeaders: { 'X-Requested-With': 'XMLHttpRequest' },
            onSuccess: function (resp) {
                var data = null;
                try { data = resp.responseJSON || JSON.parse(resp.responseText); } catch (e) {}
                var ok = data && data.success;
                showMsg(data && data.message ? data.message : (ok ? '<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Done.')); ?>' : '<?php echo Mage::helper('core')->jsQuoteEscape($this->__('Error.')); ?>'), !!ok);
                if (ok && reload) {
                    setTimeout(function () { window.location.reload(); }, 1200);
                } else {
                    refreshStats();
                }
            },
            onFailure: function (resp) {
                showMsg('<?php echo Mage::helper('core')->jsQuoteEscape($this->__('HTTP error')); ?> ' + (resp ? resp.status : '?') + '.', false);
            },
            onComplete: function () {
                if (span) { span.textContent = label; }
                btn.disabled = false;
            }
        });
    }

    // ---- live progress (full reindex) ------------------------------------

    // Disable/enable Reindex + Process pending + Refresh together, so the
    // merchant cannot launch a second run while one is in flight.
    function setControlsDisabled(disabled) {
        ['mibizum_reindex_full', 'mibizum_reindex_drain', 'mibizum_reindex_refresh'].forEach(function (id) {
            var b = $id(id);
            if (!b) { return; }
            b.disabled = disabled;
            b.style.opacity = disabled ? '0.5' : '';
            b.style.cursor  = disabled ? 'not-allowed' : '';
        });
    }

    function showProgress(show) {
        var p = $id('mibizum_reindex_progress');
        if (p) { p.style.display = show ? 'block' : 'none'; }
    }

    function setProgress(done, total, pending) {
        var lbl = $id('mibizum_reindex_progress_label');
        var bar = $id('mibizum_reindex_bar');
        if (total > 0) {
            var pct = Math.max(0, Math.min(100, Math.round((done / total) * 100)));
            if (lbl) { lbl.textContent = T.indexing + ' ' + done.toLocaleString('en-US') + ' / ' + total.toLocaleString('en-US') + ' (' + pct + '%)'; }
            if (bar) { bar.style.width = pct + '%'; }
        } else {
            if (lbl) { lbl.textContent = T.indexing + ' (' + pending + ' ' + T.pending + ')'; }
            if (bar) { bar.style.width = '45%'; }
        }
    }

    function endProgress() {
        polling = false;
        showProgress(false);
        setControlsDisabled(false);
    }

    // Click "Reindex": confirm, lock the controls, enqueue, then poll the drain.
    function startReindex() {
        var btn = $id('mibizum_reindex_full');
        if (btn && btn.disabled) { return; }
        var confirmMsg = btn ? btn.getAttribute('data-mibizum-confirm') : '';
        if (confirmMsg && !window.confirm(confirmMsg)) { return; }

        setControlsDisabled(true);
        showProgress(true);
        reindexTotal = 0;
        setProgress(0, 0, 0);

        new Ajax.Request(FULL_URL, {
            method: 'post',
            parameters: { form_key: FORM_KEY },
            requestHeaders: { 'X-Requested-With': 'XMLHttpRequest' },
            onSuccess: function (resp) {
                var d = null;
                try { d = resp.responseJSON || JSON.parse(resp.responseText); } catch (e) {}
                if (!d || !d.success) { showMsg(d && d.message ? d.message : T.genErr, false); endProgress(); return; }
                reindexTotal = Number(d.total || 0);
                setProgress(0, reindexTotal, reindexTotal);
                pollProgress();
            },
            onFailure: function (resp) {
                showMsg(T.httpErr + ' ' + (resp ? resp.status : '?') + '.', false);
                endProgress();
            }
        });
    }

    // Poll loop: each tick drains a small batch server-side and reports counts.
    function pollProgress() {
        if (polling) { return; }
        polling = true;
        failStreak = 0;
        (function tick() {
            new Ajax.Request(PROGRESS_URL, {
                method: 'post',
                parameters: { form_key: FORM_KEY },
                requestHeaders: { 'X-Requested-With': 'XMLHttpRequest' },
                onSuccess: function (resp) {
                    failStreak = 0;
                    var d = null;
                    try { d = resp.responseJSON || JSON.parse(resp.responseText); } catch (e) {}
                    if (!d || !d.success) { showMsg(d && d.message ? d.message : T.genErr, false); endProgress(); return; }

                    var total = Number(d.total || reindexTotal || 0);
                    if (total > reindexTotal) { reindexTotal = total; }
                    var pending = Number(d.pending || 0);
                    var done = (d.done !== null && typeof d.done !== 'undefined')
                        ? Number(d.done)
                        : (reindexTotal ? Math.max(0, reindexTotal - pending) : 0);

                    if (d.indexed !== null && typeof d.indexed !== 'undefined') {
                        var dc = $id('mibizum_reindex_docs');
                        if (dc) { dc.textContent = Number(d.indexed).toLocaleString('en-US'); }
                    }
                    var pEl = $id('mibizum_reindex_pending');
                    if (pEl) { pEl.textContent = pending; }
                    setProgress(done, reindexTotal, pending);

                    if (d.running) {
                        setTimeout(tick, 900); // ~1 update/second
                    } else {
                        endProgress();
                        var failed = Number(d.failed || 0);
                        var finalTotal = reindexTotal || done;
                        if (failed > 0) {
                            showMsg(T.doneErrors.replace('%s', failed), false);
                        } else {
                            showMsg(T.done.replace('%s', finalTotal.toLocaleString('en-US')), true);
                        }
                        // Reload so the "Last full reindex" badge + counts refresh.
                        setTimeout(function () { window.location.reload(); }, 2600);
                    }
                },
                onFailure: function (resp) {
                    failStreak++;
                    if (failStreak <= 5) {
                        setTimeout(tick, 1600); // transient (slow batch / blip): retry
                    } else {
                        showMsg(T.httpErr + ' ' + (resp ? resp.status : '?') + '.', false);
                        endProgress();
                    }
                }
            });
        })();
    }

    document.observe('dom:loaded', function () {
        // Process pending (and any other generic action buttons).
        var btns = document.querySelectorAll('.mibizum-reindex-btn');
        for (var i = 0; i < btns.length; i++) {
            (function (b) { b.addEventListener('click', function () { runAction(b); }); })(btns[i]);
        }
        // Reindex -> live, progress-tracked.
        var full = $id('mibizum_reindex_full');
        if (full) { full.addEventListener('click', function () { startReindex(); }); }
        var r = $id('mibizum_reindex_refresh');
        if (r) { r.addEventListener('click', function () { refreshStats(); }); }
        if (DEBUG) { refreshStats(); }

        // The page was loaded mid-reindex (e.g. the merchant refreshed): re-attach
        // to the running drain instead of looking idle.
        if (RESUME) {
            setControlsDisabled(true);
            showProgress(true);
            setProgress(0, 0, <?php echo (int) ($qPending + $qLocked); ?>);
            pollProgress();
        }
    });
})();
//]]>
</script>

    <!-- Pause / Resume toggle -->
    <div style="margin-top:14px; max-width:620px;">
        <?php if ($paused): ?>
        <button type="button" class="scalable mibizum-reindex-btn" style="font-weight:600; color:#3c763d;"
                data-mibizum-url="<?php echo $this->getResumeUrl(); ?>"
                data-mibizum-reload="1"
                title="<?php echo Mage::helper('core')->quoteEscape($this->__('Resume processing the queue for this store view.')); ?>">
            <span>▶ <?php echo $this->__('Resume sync'); ?></span>
        </button>
        <?php else: ?>
        <button type="button" class="scalable mibizum-reindex-btn" style="font-weight:normal; color:#8a6d3b;"
                data-mibizum-url="<?php echo $this->getPauseUrl(); ?>"
                data-mibizum-reload="1"
                data-mibizum-confirm="<?php echo Mage::helper('core')->quoteEscape($this->__('Pause sync for this store view? The queue will be preserved and you can resume later.')); ?>"
                title="<?php echo Mage::helper('core')->quoteEscape($this->__('Pause the sync. The queue stays intact; resume to continue where it left off.')); ?>">
            <span>⏸ <?php echo $this->__('Pause sync'); ?></span>
        </button>
        <?php endif; ?>
    </div>

    <?php endif; /* $configured */ ?>
