<?php
/**
 * "Reindex" fieldset - index status + actions.
 *
 * Embedded in System (Configuration (Mibizum Sync (General configuration.
 * Shows the status visually; the raw status only in debug mode.
 *
 * @var Mibizum_Sync_Block_Adminhtml_Reindex $this
 */
$storeId     = $this->getCurrentStoreViewId();
$configured  = $this->isCurrentStoreConfigured();
$paused      = $this->isPaused();

$last  = $this->getLastReindex();
$queue = $this->getQueueStats();
$docs  = $this->getIndexDocCount();
$debug = $this->isDebugMode();

$qPending = isset($queue['pending']) ? (int) $queue['pending'] : 0;
$qLocked  = isset($queue['locked'])  ? (int) $queue['locked']  : 0;

// Resume the live progress view when the page is loaded WHILE a reindex is
// running (status flagged 'running', or there are queued/in-flight items): the
// console re-attaches to the drain instead of looking idle.
$resumeRunning = ($last['status'] === 'running') || ($qPending + $qLocked > 0);

$statusMap = array(
    'success' => array('successful',   '#3c763d', '#dff0d8'),
    'partial' => array('with errors',  '#8a6d3b', '#fcf8e3'),
    'failed'  => array('failed',       '#a94442', '#f2dede'),
);
$st = isset($statusMap[$last['status']]) ? $statusMap[$last['status']] : null;
?>
<div class="mibizum-reindex" style="margin: 6px 0 4px;">

