                    <span id="mibizum_reindex_pending"><?php echo (int) $qPending; ?></span>
                    <span id="mibizum_reindex_pending_zero" style="color:#3c763d; font-weight:normal; font-size:11px; margin-left:6px; <?php echo $qPending > 0 ? 'display:none;' : ''; ?>"><?php echo $this->__('(all up to date)'); ?></span>
                    <span id="mibizum_reindex_locked" style="color:#999; font-weight:normal; font-size:11px; margin-left:6px; <?php echo $qLocked > 0 ? '' : 'display:none;'; ?>"><?php echo $this->__('· %s in progress', '<b class="v">' . (int) $qLocked . '</b>'); ?></span>
                    <button type="button" id="mibizum_reindex_refresh" class="scalable" style="margin-left:14px; font-weight:normal;">
                        <span><?php echo $this->__('Refresh status'); ?></span>
