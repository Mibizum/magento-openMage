                    <button type="button" id="mibizum_reindex_drain" class="scalable mibizum-reindex-btn" style="margin-left:6px; font-weight:normal;"
                            data-mibizum-url="<?php echo $this->getDrainQueueUrl(); ?>"
                            data-mibizum-reload="0"
                            data-mibizum-confirm="<?php echo Mage::helper('core')->quoteEscape($this->__('{pending} product(s) with pending changes will be processed and updated in the search index. Proceed?')); ?>"
                            title="<?php echo Mage::helper('core')->quoteEscape($this->__('Processes only the queued changes. Fast. The system already does this on its own every night.')); ?>">
