<?php
/**
 * Visual widget for the NATURE (category) Badge form.
 *
 * Only covers category badges. System badges (out of stock, on sale, etc.)
 * have their own template system_badge_form.phtml - they are not mixed here.
 *
 * Visual pickers for: color (palette derived from existing badges +
 * custom HTML5 picker), position (5 corners), shape (3 shapes), display_mode
 * (icon/text/both), icon (drop-zone PNG/SVG/JPG/WebP). Plus category
 * assignment with autocomplete.
 *
 * @var Mage_Adminhtml_Block_Template $this
 *   $this->getBadgeId()    int|null
 *   $this->getBadgeModel() Mibizum_Sync_Model_Nature
 */

$model = $this->getBadgeModel();
$badgeId = (int) $this->getBadgeId();

// $searchUrl: no longer rendered at the template root - the helper's
// mibizum-multiselect-table widget receives the URL directly when building
// the markup below.
$searchUrl       = $this->getUrl('adminhtml/mibizum_sync_nature/searchCategories');
$uploadUrl       = $this->getUrl('adminhtml/mibizum_sync_nature/uploadIcon');
$paletteUrl      = $this->getUrl('adminhtml/mibizum_sync_nature/palette');
$suggestTextUrl  = $this->getUrl('adminhtml/mibizum_sync_nature/suggestTextColor');

$curColor       = $model && $model->getColorHex()    ? $model->getColorHex()    : '#1E9C3C';
$curTextColor   = $model && $model->getTextColorHex() ? $model->getTextColorHex() : '#FFFFFF';
$curPosition    = $model && $model->getPosition()    ? $model->getPosition()    : 'bottom_left';
$curShape       = $model && $model->getShape()       ? $model->getShape()       : 'pill';
$curDisplayMode = $model && $model->getDisplayMode() ? $model->getDisplayMode() : 'icon_and_text';
$curIconSvg     = $model ? (string) $model->getIconSvg() : '';
$curIconUrl     = $model ? (string) $model->getIconUrl() : '';
$curIconFaClass = $model ? (string) $model->getIconFaClass() : '';

// Load the FA 4.7 icon list from the data file. 786 entries,
// served to the JS as a JSON array for autocomplete.
$faListPath = Mage::getBaseDir('app') . DS . 'code' . DS . 'community' . DS . 'Mibizum' . DS . 'Sync' . DS . 'etc' . DS . 'fa47-icons.txt';
$faIcons = array();
if (is_readable($faListPath)) {
    $faIcons = array_filter(array_map('trim', file($faListPath)));
    $faIcons = array_values($faIcons);
}
$faIconsJson = htmlspecialchars(json_encode($faIcons, JSON_UNESCAPED_SLASHES), ENT_QUOTES);

// Font Awesome CSS URL (frontend, already loaded by the theme via Plumrocket
// Pramp). We also include it in admin so the preview + autocomplete render
// the real icon, not just its textual name.
$faCssUrl = Mage::getBaseUrl(Mage_Core_Model_Store::URL_TYPE_SKIN)
    . 'frontend/base/default/css/plumrocket/pramp/font-awesome.min.css';

// Pre-load category assignments (delegated to the helper, same format
// consumed by the mibizum-multiselect-table widget).
$catAssignments = Mage::helper('mibizum_sync')
    ->loadCategoryAssignmentsForBadge('mibizum_sync/natureCategory', $badgeId);
?>
